# ─── Neon PostgreSQL ────────────────────────────────────────────────────────
# Obter em: https://console.neon.tech → seu projeto → Connection Details
#
# DATABASE_URL  → usa connection pooler (Prisma queries normais)
# DIRECT_URL    → conexão direta (Prisma migrations)
#
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Gerar secret: openssl rand -base64 32
