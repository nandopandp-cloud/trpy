generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth compatible) ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  image         String?
  password      String?   // hashed — null for OAuth-only users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  trips         Trip[]
  favorites     Favorite[]
  placeReviews  PlaceReview[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model VerificationCode {
  id         String   @id @default(cuid())
  email      String
  phone      String?
  code       String
  type       String   @default("signup") // "signup" | "reset"
  expiresAt  DateTime
  verified   Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([email, code])
  @@map("verification_codes")
}

// ─── Trips ───────────────────────────────────────────────────────────────────

enum TripStatus {
  PLANNING
  ONGOING
  COMPLETED
  CANCELLED
}

model Trip {
  id          String     @id @default(cuid())
  userId      String
  title       String
  destination String
  description String?
  coverImage  String?
  startDate   DateTime
  endDate     DateTime
  budget      Decimal    @db.Decimal(10, 2)
  totalSpent  Decimal    @default(0) @db.Decimal(10, 2)
  currency    String     @default("BRL")
  status      TripStatus @default(PLANNING)
  isDeleted   Boolean    @default(false)
  shareToken  String?    @unique  // public share token — null means sharing disabled
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  itineraryDays  ItineraryDay[]
  expenses       Expense[]

  @@index([userId])
  @@index([status])
  @@index([shareToken])
  @@map("trips")
}

// ─── Itinerary ───────────────────────────────────────────────────────────────

model ItineraryDay {
  id        String   @id @default(cuid())
  tripId    String
  dayNumber Int
  date      DateTime
  title     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip  Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items ItineraryItem[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
  @@map("itinerary_days")
}

enum ItemType {
  ACTIVITY
  RESTAURANT
  HOTEL
  TRANSPORT
  OTHER
}

model ItineraryItem {
  id           String    @id @default(cuid())
  dayId        String
  type         ItemType  @default(ACTIVITY)
  title        String
  description  String?
  location     String?
  latitude     Decimal?  @db.Decimal(9, 6)
  longitude    Decimal?  @db.Decimal(9, 6)
  startTime    String?
  durationMins Int?
  cost         Decimal?  @db.Decimal(10, 2)
  currency     String    @default("BRL")
  bookingUrl   String?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@map("itinerary_items")
}

// ─── Favorites ───────────────────────────────────────────────────────────────

enum FavoriteType {
  PLACE
  RESTAURANT
  HOTEL
  ACTIVITY
  VIDEO
  PIN
}

model Favorite {
  id              String       @id @default(cuid())
  userId          String
  type            FavoriteType
  externalId      String
  name            String
  image           String?
  rating          Decimal?     @db.Decimal(3, 1)
  googlePlaceId   String?
  youtubeVideoId  String?
  pinterestPinId  String?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, externalId])
  @@index([userId])
  @@index([type])
  @@map("favorites")
}

// ─── Place Reviews ───────────────────────────────────────────────────────────

model PlaceReview {
  id           String   @id @default(cuid())
  userId       String
  googlePlaceId String
  placeName    String
  rating       Int      // 1-5
  title        String?
  body         String?
  visitedOn    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googlePlaceId])
  @@index([googlePlaceId])
  @@index([userId])
  @@map("place_reviews")
}

// ─── Expenses ────────────────────────────────────────────────────────────────

enum ExpenseCategory {
  ACCOMMODATION
  FOOD
  TRANSPORT
  ACTIVITIES
  SHOPPING
  HEALTH
  OTHER
}

model Expense {
  id          String          @id @default(cuid())
  tripId      String
  category    ExpenseCategory @default(OTHER)
  title       String
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("BRL")
  date        DateTime
  notes       String?
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([category])
  @@map("expenses")
}

// ─── API Usage — cost tracking + kill switch ────────────────────────────────
// Persiste o custo acumulado de chamadas a APIs externas (hoje: Google Places)
// por mês. Serve de base para o circuit breaker: quando o custo ultrapassa o
// limite configurado, o wrapper no backend para de chamar o Google e entra em
// modo degradado (retorna apenas resultados da base local).

model ApiUsage {
  id          String   @id @default(cuid())
  /// Provider da API — "google_places" por enquanto, extensível
  provider    String
  /// Chave do período no formato YYYY-MM (UTC)
  period      String
  /// Tipo da operação (autocomplete, details, text_search, photo, geocode)
  operation   String
  /// Quantidade de chamadas realizadas no período
  callCount   Int      @default(0)
  /// Custo acumulado no período em centavos de USD (evita drift de float)
  costCents   Int      @default(0)
  /// Flag de kill switch manual
  killed      Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([provider, period, operation])
  @@index([provider, period])
  @@map("api_usage")
}

// ─── Cache persistente de Google Place Details ──────────────────────────────
// Edge cache (24h via revalidate) some entre redeploys e em cold start.
// Esta tabela mantém a resposta serializada por placeId+tier, com TTL longo
// (30 dias) — sobrevive deploys e elimina re-cobrança quando o mesmo lugar
// é aberto por usuários diferentes ou em devices diferentes.
//
// Atomic data (rating, opening_hours) muda raramente; 30 dias é seguro.
// Se o Google mostrar discrepância, basta truncar a tabela ou esperar TTL.
model PlaceCache {
  id          String   @id @default(cuid())
  /// Google place_id (chave primária lógica)
  placeId     String
  /// "basic" ou "full" — SKU de campos solicitados ao Google
  tier        String
  /// JSON serializado da resposta do Place Details
  payload    Json
  /// Quando o registro expira (now + 30d). Reads ignoram registros >= expiresAt.
  expiresAt  DateTime
  fetchedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([placeId, tier])
  @@index([expiresAt])
  @@map("place_cache")
}

