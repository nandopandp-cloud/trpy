# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.neon.tech/neondb?sslmode=require"

# Authentication
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# OAuth — Apple (https://developer.apple.com/account/resources/identifiers)
APPLE_CLIENT_ID="com.trpy.web"
APPLE_CLIENT_SECRET="xxx"

# Google APIs
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIza..."
GOOGLE_PLACES_API_KEY="AIza..."

# YouTube Data API v3
NEXT_PUBLIC_YOUTUBE_API_KEY="AIza..."

# Pinterest API
PINTEREST_ACCESS_TOKEN="pina_YOUR_ACCESS_TOKEN_HERE"
PINTEREST_BUSINESS_ACCOUNT_ID="1561250"

# AI
ANTHROPIC_API_KEY="sk-ant-..."

# Media
CLOUDINARY_CLOUD_NAME="xxx"

# Media Engine — Unsplash & Pexels (images and videos)
# Get keys from: https://unsplash.com/oauth/applications and https://www.pexels.com/api/
UNSPLASH_ACCESS_KEY="xxx"
PEXELS_API_KEY="xxx"
